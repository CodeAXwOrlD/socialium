# Socialium Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL=sqlite+aiosqlite:///./socialium.db

# ==========================================
# Authentication (Supabase)
# ==========================================
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
JWT_SECRET=your_jwt_secret_key

# ==========================================
# LinkedIn OAuth
# ==========================================
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/platforms

# ==========================================
# Twitter/X OAuth
# ==========================================
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
TWITTER_REDIRECT_URI=http://localhost:3000/platforms/twitter/callback

# ==========================================
# Instagram/Facebook OAuth
# ==========================================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
INSTAGRAM_REDIRECT_URI=http://localhost:3000/platforms/instagram/callback

# ==========================================
# Google OAuth
# ==========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ==========================================
# Twilio (WhatsApp & SMS)
# ==========================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# ==========================================
# WapiHub (WhatsApp Business API)
# ==========================================
WAPIHUB_API_KEY=your_wapihub_api_key

# ==========================================
# AI/LLM Services
# ==========================================
OPENAI_API_KEY=your_openai_api_key
GROQ_API_KEY=your_groq_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ==========================================
# Observability & Analytics
# ==========================================
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
POSTHOG_API_KEY=your_posthog_api_key
SENTRY_DSN=your_sentry_dsn

# ==========================================
# Qdrant (Vector Database)
# ==========================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key

# ==========================================
# Application Settings
# ==========================================
SECRET_KEY=your_application_secret_key_for_sessions
ENVIRONMENT=development
DEBUG=true
