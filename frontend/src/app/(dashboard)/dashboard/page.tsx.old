"use client";

import { motion } from "framer-motion";
import { useQuery } from "@tanstack/react-query";
import { useState, useEffect } from "react";
import Link from "next/link";
import { listContent } from "@/services/content";
import { listScheduled } from "@/services/scheduling";
import { getStoredUser } from "@/lib/auth";
import { requireWorkspaceId } from "@/lib/workspace";

// Animated counter hook
function useCounter(target: number, duration = 1500) {
  const [count, setCount] = useState(0);
  useEffect(() => {
    if (target === 0) {
      setCount(0);
      return;
    }
    const step = target / (duration / 16);
    let current = 0;
    const timer = setInterval(() => {
      current += step;
      if (current >= target) {
        setCount(target);
        clearInterval(timer);
      } else {
        setCount(Math.floor(current));
      }
    }, 16);
    return () => clearInterval(timer);
  }, [target, duration]);
  return count;
}

// Stat card with glow and animation
function StatCard({
  title,
  value,
  change,
  icon,
  color,
  delay,
  description,
  action,
}: {
  title: string;
  value: number;
  change?: number;
  icon: string;
  color: "indigo" | "violet" | "emerald" | "amber";
  delay: number;
  description?: string;
  action?: { label: string; href: string };
}) {
  const animatedValue = useCounter(value);

  const colorMap = {
    indigo:
      "from-indigo-500/20 to-indigo-600/5 border-indigo-500/20 shadow-indigo-500/10",
    violet:
      "from-violet-500/20 to-violet-600/5 border-violet-500/20 shadow-violet-500/10",
    emerald:
      "from-emerald-500/20 to-emerald-600/5 border-emerald-500/20 shadow-emerald-500/10",
    amber:
      "from-amber-500/20 to-amber-600/5 border-amber-500/20 shadow-amber-500/10",
  };

  const iconColorMap = {
    indigo: "bg-indigo-500/20 text-indigo-400",
    violet: "bg-violet-500/20 text-violet-400",
    emerald: "bg-emerald-500/20 text-emerald-400",
    amber: "bg-amber-500/20 text-amber-400",
  };

  return (
    <motion.div
      initial={{ opacity: 0, y: 20 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ delay, duration: 0.4, ease: "easeOut" }}
      whileHover={{ y: -4, transition: { duration: 0.2 } }}
      className={`relative overflow-hidden rounded-2xl border bg-gradient-to-br ${colorMap[color]} p-6 shadow-lg cursor-pointer group`}
    >
      {/* Shimmer on hover */}
      <div className="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity shimmer pointer-events-none" />

      {/* Corner decoration */}
      <div
        className={`absolute -top-6 -right-6 w-24 h-24 rounded-full bg-gradient-to-br opacity-10 blur-2xl`}
      />

      <div className="relative">
        {/* Header */}
        <div className="flex items-center justify-between mb-4">
          <div
            className={`w-10 h-10 rounded-xl flex items-center justify-center ${iconColorMap[color]}`}
          >
            <span className="text-lg">{icon}</span>
          </div>
          {change !== undefined && (
            <div
              className={`flex items-center gap-1 text-[10px] font-bold px-2 py-1 rounded-full ${
                change >= 0
                  ? "bg-emerald-500/10 text-emerald-400"
                  : "bg-red-500/10 text-red-400"
              }`}
            >
              <span>{change >= 0 ? "↑" : "↓"}</span>
              <span>{Math.abs(change)}%</span>
            </div>
          )}
        </div>

        {/* Value */}
        <div className="mb-1">
          <span className="text-3xl font-display font-bold text-white">
            {value === 0 ? "0" : animatedValue.toLocaleString()}
          </span>
        </div>

        {/* Title */}
        <p className="text-sm text-white/50 font-medium tracking-tight">
          {title}
        </p>

        {/* Description */}
        {description && (
          <p className="text-[10px] text-white/30 mt-1 font-medium italic">
            {description}
          </p>
        )}

        {/* Action link */}
        {action && value === 0 && (
          <Link
            href={action.href}
            className="inline-flex items-center gap-1 text-[10px] font-bold text-brand-500 hover:text-brand-400 mt-4 transition-all uppercase tracking-widest"
          >
            {action.label} →
          </Link>
        )}
      </div>
    </motion.div>
  );
}

// Live activity feed
function ActivityFeed({ items }: { items: any[] }) {
  return (
    <div className="space-y-1">
      {items.length === 0 ? (
        <div className="flex flex-col items-center justify-center py-12 text-center">
          <div className="w-16 h-16 rounded-2xl bg-white/5 flex items-center justify-center mb-4 text-2xl grayscale opacity-50">
            📭
          </div>
          <p className="text-white/40 text-sm font-medium">No activity yet</p>
          <p className="text-white/20 text-xs mt-1">
            Create your first post to see activity here
          </p>
        </div>
      ) : (
        items.map((item, i) => (
          <motion.div
            key={i}
            initial={{ opacity: 0, x: -20 }}
            animate={{ opacity: 1, x: 0 }}
            transition={{ delay: i * 0.05 }}
            className="flex items-start gap-3 py-3 border-b border-white/5 last:border-0 group hover:bg-white/[0.02] px-3 rounded-xl -mx-2 transition-all cursor-pointer"
          >
            <div className="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center flex-shrink-0 text-sm group-hover:scale-110 transition-transform">
              {item.icon}
            </div>
            <div className="flex-1 min-w-0">
              <p className="text-white/70 text-xs leading-relaxed font-medium">
                {item.description}
              </p>
              <p className="text-white/20 text-[10px] mt-0.5 font-bold uppercase tracking-wider">
                {item.time}
              </p>
            </div>
            <div
              className={`w-1.5 h-1.5 rounded-full flex-shrink-0 mt-2 ${
                item.type === "success"
                  ? "bg-emerald-400"
                  : item.type === "warning"
                  ? "bg-amber-400"
                  : item.type === "error"
                  ? "bg-red-400"
                  : "bg-brand-500"
              }`}
            />
          </motion.div>
        ))
      )}
    </div>
  );
}

// AI insights panel
function AIInsightCard({ insight, delay }: { insight: any; delay: number }) {
  return (
    <motion.div
      initial={{ opacity: 0, scale: 0.95 }}
      animate={{ opacity: 1, scale: 1 }}
      transition={{ delay }}
      className="relative overflow-hidden rounded-2xl border border-white/5 bg-white/[0.02] p-4 group hover:bg-white/[0.05] transition-all cursor-pointer"
    >
      <div className="absolute inset-0 bg-gradient-to-br from-indigo-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" />
      <div className="relative flex items-start gap-4">
        <div className="w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-500/20 to-violet-500/20 flex items-center justify-center flex-shrink-0 text-lg shadow-inner">
          {insight.icon}
        </div>
        <div>
          <p className="text-white/80 text-xs font-semibold leading-relaxed tracking-tight">
            {insight.text}
          </p>
          <p className="text-brand-500 text-[10px] mt-1.5 font-black uppercase tracking-widest">
            {insight.action}
          </p>
        </div>
      </div>
    </motion.div>
  );
}

// Onboarding progress
function OnboardingCard({ steps }: { steps: any[] }) {
  const completed = steps.filter((s) => s.done).length;
  const progress = (completed / steps.length) * 100;

  if (completed === steps.length) return null;

  return (
    <motion.div
      initial={{ opacity: 0, y: 20 }}
      animate={{ opacity: 1, y: 0 }}
      className="relative overflow-hidden rounded-3xl border border-indigo-500/20 bg-gradient-to-br from-indigo-500/10 to-violet-500/5 p-8 mb-10 shadow-[0_20px_50px_rgba(99,102,241,0.1)]"
    >
      {/* Background decoration */}
      <div className="absolute top-0 right-0 w-80 h-80 bg-indigo-500/10 rounded-full blur-[100px] pointer-events-none" />

      <div className="relative">
        <div className="flex items-center justify-between mb-6">
          <div>
            <h3 className="text-white font-bold text-lg tracking-tight">
              Get started with Socialium ✦
            </h3>
            <p className="text-white/40 text-xs mt-1 font-medium">
              {completed} of {steps.length} steps completed
            </p>
          </div>
          <div className="text-right">
            <p className="text-3xl font-black gradient-text">
              {Math.round(progress)}%
            </p>
          </div>
        </div>

        {/* Progress bar */}
        <div className="h-2 bg-white/5 rounded-full mb-8 overflow-hidden border border-white/5">
          <motion.div
            initial={{ width: 0 }}
            animate={{ width: `${progress}%` }}
            transition={{ duration: 1.2, ease: [0.19, 1, 0.22, 1] }}
            className="h-full bg-gradient-to-r from-indigo-500 via-violet-500 to-brand-500 rounded-full shadow-[0_0_15px_rgba(99,102,241,0.4)]"
          />
        </div>

        {/* Steps */}
        <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
          {steps.map((step, i) => (
            <motion.div
              key={step.label}
              initial={{ opacity: 0, y: 10 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: i * 0.1 }}
              className={`flex items-center gap-4 p-4 rounded-2xl transition-all ${
                step.done
                  ? "opacity-40 border border-white/5"
                  : "bg-white/5 border border-white/10 hover:bg-white/8 cursor-pointer shadow-lg"
              }`}
            >
              <div
                className={`w-8 h-8 rounded-xl flex items-center justify-center flex-shrink-0 text-xs font-bold ${
                  step.done
                    ? "bg-emerald-500/20 text-emerald-400"
                    : "bg-indigo-500/20 text-indigo-400"
                }`}
              >
                {step.done ? "✓" : i + 1}
              </div>
              <div className="flex-1">
                <p
                  className={`text-xs font-bold tracking-tight ${
                    step.done ? "text-white/40 line-through" : "text-white/80"
                  }`}
                >
                  {step.label}
                </p>
              </div>
              {!step.done && (
                <Link
                  href={step.href}
                  className="text-[9px] text-white font-black px-2 py-1 rounded-lg bg-indigo-500 shadow-lg shadow-indigo-500/20 hover:scale-105 transition-all uppercase tracking-widest"
                >
                  {step.cta}
                </Link>
              )}
            </motion.div>
          ))}
        </div>
      </div>
    </motion.div>
  );
}

export default function DashboardPage() {
  const workspaceId = requireWorkspaceId();
  
  const { data: content } = useQuery({
    queryKey: ["content", "recent", workspaceId],
    queryFn: () => listContent(workspaceId).then((res) => res.slice(0, 5)),
    enabled: !!workspaceId,
  });

  const { data: scheduled } = useQuery({
    queryKey: ["scheduled", "upcoming", workspaceId],
    queryFn: () => listScheduled().then((res) => res.slice(0, 5)),
    enabled: !!workspaceId,
  });

  const user = getStoredUser();
  const firstName =
    user?.full_name?.split(" ")[0] || user?.username || "Friend";

  const totalPosts = content?.length || 0;
  const scheduledCount = scheduled?.length || 0;
  const publishedCount =
    content?.filter((c) => c.status === "published").length || 0;
  const aiGeneratedCount =
    content?.filter((c) => c.source_type === "ai_generated").length || 0;

  const stats = [
    {
      title: "Total Content",
      value: totalPosts,
      change: 12,
      icon: "✦",
      color: "indigo" as const,
      delay: 0.1,
      description: "Posts created this month",
      action: { label: "Create your first post", href: "/content/generate" },
    },
    {
      title: "Scheduled",
      value: scheduledCount,
      icon: "◈",
      color: "violet" as const,
      delay: 0.15,
      description: "Posts in the queue",
      action: { label: "Schedule content", href: "/scheduling" },
    },
    {
      title: "Published",
      value: publishedCount,
      change: 8,
      icon: "◉",
      color: "emerald" as const,
      delay: 0.2,
      description: "Successfully published",
    },
    {
      title: "AI Generated",
      value: aiGeneratedCount,
      icon: "⟡",
      color: "amber" as const,
      delay: 0.25,
      description: "Created by AI this month",
    },
  ];

  const onboardingSteps = [
    {
      label: "Connect platforms",
      href: "/platforms",
      cta: "Connect",
      done: false, // In real app, check if platforms are connected
    },
    {
      label: "Generate AI post",
      href: "/content/generate",
      cta: "Create",
      done: totalPosts > 0,
    },
    {
      label: "Schedule content",
      href: "/scheduling",
      cta: "Schedule",
      done: scheduledCount > 0,
    },
  ];

  const aiInsights = [
    {
      icon: "🔥",
      text: "LinkedIn posts with a question in the hook get 47% more comments",
      action: "Try it →",
    },
    {
      icon: "⏰",
      text: "Best time to post on LinkedIn is Tuesday at 9am for B2B audiences",
      action: "Optimize →",
    },
    {
      icon: "🎯",
      text: "Posts under 1,000 characters on LinkedIn get 24% more impressions",
      action: "Analyze →",
    },
  ];

  const activities = (content || []).map((item) => ({
    icon: item.status === "published" ? "✅" : "📝",
    description: `New content "${item.title || "Untitled"}" created for ${
      item.platform || "unknown"
    }`,
    time: "Today",
    type: item.status === "published" ? "success" : "info",
  }));

  return (
    <div className="min-h-screen bg-transparent dark:bg-transparent light:bg-transparent">
      {/* Page header */}
      <motion.div
        initial={{ opacity: 0, y: -10 }}
        animate={{ opacity: 1, y: 0 }}
        className="mb-10"
      >
        <h1 className="text-3xl font-display font-black text-white dark:text-white light:text-gray-900 tracking-tight">
          Good morning, {firstName} ✦
        </h1>
        <p className="text-white/40 dark:text-white/40 light:text-gray-500 text-sm mt-1.5 font-medium italic">
          Here's what's happening with your content pipeline today.
        </p>
      </motion.div>

      {/* Onboarding card */}
      <OnboardingCard steps={onboardingSteps} />

      {/* Stats grid */}
      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
        {stats.map((stat) => (
          <StatCard key={stat.title} {...stat} />
        ))}
      </div>

      {/* Main content grid */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {/* Activity feed */}
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.3 }}
          className="lg:col-span-2 rounded-3xl border border-white/5 bg-white/[0.02] p-8 shadow-2xl"
        >
          <div className="flex items-center justify-between mb-8">
            <div>
              <h2 className="text-white font-bold text-lg tracking-tight">
                Recent Activity
              </h2>
              <p className="text-white/30 text-xs mt-1 font-medium">
                Real-time updates from your pipeline
              </p>
            </div>
            <div className="flex items-center gap-2 bg-emerald-500/10 px-3 py-1.5 rounded-full border border-emerald-500/20">
              <div className="w-2 h-2 bg-emerald-400 rounded-full animate-pulse" />
              <span className="text-emerald-400 text-[10px] font-black uppercase tracking-widest">
                Live
              </span>
            </div>
          </div>
          <ActivityFeed items={activities} />
        </motion.div>

        {/* AI insights */}
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.35 }}
          className="rounded-3xl border border-white/5 bg-white/[0.02] p-8 shadow-2xl"
        >
          <div className="flex items-center gap-3 mb-8">
            <div className="w-8 h-8 rounded-xl bg-gradient-to-br from-indigo-500/20 to-violet-500/20 flex items-center justify-center text-lg">
              🤖
            </div>
            <div>
              <h2 className="text-white font-bold text-lg tracking-tight">
                AI Insights
              </h2>
              <p className="text-white/30 text-xs mt-1 font-medium">
                Personalized for you
              </p>
            </div>
          </div>
          <div className="space-y-4">
            {aiInsights.map((insight, i) => (
              <AIInsightCard key={i} insight={insight} delay={0.4 + i * 0.05} />
            ))}
          </div>
        </motion.div>
      </div>

      {/* Quick actions bar */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ delay: 0.5 }}
        className="mt-10 flex items-center gap-4 flex-wrap pb-10"
      >
        <p className="text-white/20 text-xs font-bold uppercase tracking-widest">
          Quick actions:
        </p>
        {[
          {
            label: "✨ Generate content",
            href: "/content/generate",
            primary: true,
          },
          { label: "📅 View schedule", href: "/scheduling" },
          { label: "📊 See analytics", href: "/analytics" },
          { label: "🔗 Connect platform", href: "/platforms" },
        ].map((action) => (
          <Link
            key={action.label}
            href={action.href}
            className={`text-[10px] font-black px-4 py-2 rounded-xl transition-all uppercase tracking-widest ${
              action.primary
                ? "bg-brand-500 text-white hover:bg-brand-400 shadow-lg shadow-brand-500/20"
                : "bg-white/5 text-white/40 hover:bg-white/10 hover:text-white/80 border border-white/5"
            }`}
          >
            {action.label}
          </Link>
        ))}
      </motion.div>
    </div>
  );
}
