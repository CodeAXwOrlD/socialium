"use client";

import { useEffect, useState } from "react";
import { BarChart3, TrendingUp, Heart, MessageCircle, Share2, Loader2 } from "lucide-react";
import { capitalize } from "@/lib/utils";
import { getAnalyticsOverview } from "@/services/analytics";
import { requireWorkspaceId } from "@/lib/workspace";
import toast from "react-hot-toast";

export default function AnalyticsPage() {
  const workspaceId = requireWorkspaceId();
  const [loading, setLoading] = useState(true);
  const [analytics, setAnalytics] = useState<any>(null);
  const [days, setDays] = useState(30);

  useEffect(() => {
    if (!workspaceId) return;
    
    setLoading(true);
    getAnalyticsOverview(workspaceId)
      .then((data) => {
        setAnalytics(data);
      })
      .catch((err) => {
        console.error("Failed to load analytics:", err);
        toast.error("Failed to load analytics");
      })
      .finally(() => setLoading(false));
  }, [workspaceId, days]);

  if (loading) {
    return (
      <div className="flex items-center justify-center min-h-[400px]">
        <Loader2 className="h-8 w-8 animate-spin text-brand-500" />
      </div>
    );
  }

  const stats = [
    { label: "Total Posts", value: analytics?.total_posts || 0, icon: BarChart3, color: "bg-blue-500/10 text-blue-400" },
    { label: "Total Engagement", value: analytics?.total_engagement || 0, icon: TrendingUp, color: "bg-emerald-500/10 text-emerald-400" },
    { label: "Total Likes", value: analytics?.total_likes || 0, icon: Heart, color: "bg-pink-500/10 text-pink-400" },
    { label: "Comments", value: analytics?.total_comments || 0, icon: MessageCircle, color: "bg-violet-500/10 text-violet-400" },
    { label: "Shares", value: analytics?.total_shares || 0, icon: Share2, color: "bg-amber-500/10 text-amber-400" },
  ];

  return (
    <div className="space-y-4 lg:space-y-6">
      <div className="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <h1 className="text-xl lg:text-2xl font-bold text-white">Analytics</h1>
          <p className="text-sm text-white/50 mt-1">Track performance across your platforms</p>
        </div>
        <div className="flex gap-2">
          {[30, 90, 365].map((d) => (
            <button
              key={d}
              onClick={() => setDays(d)}
              className={`px-3 py-1.5 rounded-lg text-sm font-medium transition-colors ${
                days === d
                  ? "bg-brand-500 text-white"
                  : "bg-white/5 text-white/60 hover:bg-white/10"
              }`}
            >
              {d === 30 ? "30 days" : d === 90 ? "90 days" : "1 year"}
            </button>
          ))}
        </div>
      </div>

      {/* Stats */}
      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {stats.map((stat) => (
          <div key={stat.label} className="rounded-xl border border-white/10 bg-white/[0.02] p-5">
            <div className="flex items-center justify-between">
              <p className="text-sm font-medium text-white/60">{stat.label}</p>
              <div className={`rounded-lg p-2 ${stat.color}`}>
                <stat.icon className="h-4 w-4" />
              </div>
            </div>
            <p className="mt-2 text-2xl font-bold text-white">{stat.value.toLocaleString()}</p>
          </div>
        ))}
      </div>

      {/* Platform breakdown */}
      <div className="rounded-xl border border-white/10 bg-white/[0.02] p-6">
        <h2 className="mb-4 font-semibold text-white">Platform Breakdown</h2>
        <div className="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
          {["linkedin", "twitter", "instagram", "facebook", "whatsapp"].map((platform) => (
            <div key={platform} className="rounded-lg border border-white/10 p-4 text-center">
              <p className="text-sm font-medium text-white/80">{capitalize(platform)}</p>
              <p className="mt-1 text-2xl font-bold text-white">
                {analytics?.posts_by_platform?.[platform] || 0}
              </p>
              <p className="text-xs text-white/40">posts</p>
            </div>
          ))}
        </div>
      </div>

      {/* Status breakdown */}
      <div className="rounded-xl border border-white/10 bg-white/[0.02] p-6">
        <h2 className="mb-4 font-semibold text-white">Content Status</h2>
        <div className="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {Object.entries(analytics?.posts_by_status || {}).map(([status, count]) => (
            <div key={status} className="rounded-lg border border-white/10 p-4 text-center">
              <p className="text-sm font-medium text-white/80">{capitalize(status.replace("_", " "))}</p>
              <p className="mt-1 text-2xl font-bold text-white">{count as number}</p>
              <p className="text-xs text-white/40">posts</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}
